---
import { Scissors, Zap, Shirt, Headphones } from "lucide-react";

interface Props {
  // no props needed for now
}
---

<section id="solucoes" class="bg-white py-24 w-full overflow-hidden">
  <div class="container mx-auto px-6 lg:px-12">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-start">
      {/* Left Column: Title */}
      <div class="flex flex-col justify-center h-full reveal-left">
        <h2
          class="text-4xl md:text-5xl lg:text-6xl font-bold leading-tight text-gray-900 relative z-10"
        >
          Soluções com diferencial{" "}
          <span class="relative inline-block">
            competitivo
            <svg
              class="absolute left-0 -bottom-3 w-full h-6 pointer-events-none"
              viewBox="0 0 300 30"
              fill="none"
              xmlns="http://www.w3.org/2000/svg"
              preserveAspectRatio="none"
            >
              <path
                class="glow-path"
                d="M10 20 C 60 24, 120 24, 190 22 S 270 20, 290 22"
                stroke="#86efac"
                stroke-width="10"
                stroke-linecap="round"
                opacity="0.35"
                style="filter: blur(6px); stroke-dasharray: 300; stroke-dashoffset: 300;"
              ></path>
              <path
                class="main-path"
                d="M10 20 C 60 24, 120 24, 190 22 S 270 20, 290 22"
                stroke="#84cc16"
                stroke-width="7"
                stroke-linecap="round"
                style="stroke-dasharray: 300; stroke-dashoffset: 300;"></path>
            </svg>
          </span>
          .
        </h2>
      </div>

      {/* Right Column: Content */}
      <div class="flex flex-col gap-8 reveal-right">
        <div class="space-y-6 text-lg text-gray-800 font-light leading-relaxed">
          <p>
            A indústria da moda evolui constantemente, por isso, é preciso
            inovar e estar preparado para essas mudanças.
          </p>
          <p>
            A tecnologia tem sido uma grande aliada e essencial para as
            indústrias do setor têxtil, pois permite produzir peças
            sofisticadas, com alto padrão de qualidade e baixo percentual de
            desperdício.
          </p>
          <p>
            Além disso, o aumento de produtividade e redução de custos é
            significativo, pois afetam diretamente no aumento da lucratividade e
            tornam as empresas mais competitivas.
          </p>
          <p>
            A MAB Fortuna conta com diversas soluções que vão desde bordadeiras,
            laser, passadeiras, suporte técnico, treinamentos, além da
            experiência de mais de 20 anos.
          </p>
        </div>

        {/* Badges */}
        <div class="grid grid-cols-2 md:grid-cols-2 gap-4 mt-4">
          <a href="/catalogo" class="badge-item">
            <div
              class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 border border-gray-100 hover:border-purple-100 hover:bg-purple-50/30 transition-colors group h-full"
            >
              <div
                class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center shadow-sm group-hover:border-purple-200 group-hover:shadow-md transition-all"
              >
                <Scissors className="w-5 h-5 text-[#322783]" />
              </div>
              <span
                class="text-sm font-medium text-gray-700 group-hover:text-gray-900"
                >Bordadeiras</span
              >
            </div>
          </a>
          <a href="/catalogo" class="badge-item">
            <div
              class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 border border-gray-100 hover:border-purple-100 hover:bg-purple-50/30 transition-colors group h-full"
            >
              <div
                class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center shadow-sm group-hover:border-purple-200 group-hover:shadow-md transition-all"
              >
                <Zap className="w-5 h-5 text-[#322783]" />
              </div>
              <span
                class="text-sm font-medium text-gray-700 group-hover:text-gray-900"
                >Laser</span
              >
            </div>
          </a>
          <a href="/catalogo" class="badge-item">
            <div
              class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 border border-gray-100 hover:border-purple-100 hover:bg-purple-50/30 transition-colors group h-full"
            >
              <div
                class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center shadow-sm group-hover:border-purple-200 group-hover:shadow-md transition-all"
              >
                <Shirt className="w-5 h-5 text-[#322783]" />
              </div>
              <span
                class="text-sm font-medium text-gray-700 group-hover:text-gray-900"
                >Passadeiras</span
              >
            </div>
          </a>
          <a href="/suporte" class="badge-item">
            <div
              class="flex items-center gap-3 p-3 rounded-xl bg-gray-50 border border-gray-100 hover:border-purple-100 hover:bg-purple-50/30 transition-colors group h-full"
            >
              <div
                class="flex-shrink-0 w-10 h-10 rounded-full bg-white border border-gray-100 flex items-center justify-center shadow-sm group-hover:border-purple-200 group-hover:shadow-md transition-all"
              >
                <Headphones className="w-5 h-5 text-[#322783]" />
              </div>
              <span
                class="text-sm font-medium text-gray-700 group-hover:text-gray-900"
                >Suporte Técnico</span
              >
            </div>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .reveal-left {
    opacity: 0;
    transform: translateX(-50px);
    transition: all 0.8s ease-out;
  }
  .reveal-right {
    opacity: 0;
    transform: translateX(50px);
    transition: all 0.8s ease-out 0.2s;
  }
  .active.reveal-left,
  .active.reveal-right {
    opacity: 1;
    transform: translateX(0);
  }

  .glow-path,
  .main-path {
    transition: stroke-dashoffset 2s ease-in-out;
  }

  .active .glow-path,
  .active .main-path {
    stroke-dashoffset: 0;
  }
</style>

<script>
  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          entry.target.classList.add("active");
          entry.target
            .querySelectorAll(".reveal-left, .reveal-right")
            .forEach((el) => el.classList.add("active"));
        }
      });
    },
    { threshold: 0.1 },
  );

  const section = document.querySelector("#solucoes");
  if (section) observer.observe(section);
</script>
